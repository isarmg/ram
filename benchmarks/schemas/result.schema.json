{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isarmg/ram/benchmarks/schemas/result.schema.json",
  "title": "Ram performance result",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "generated_at_utc",
    "source_commit",
    "preset",
    "runner_id",
    "environment",
    "configuration",
    "profiles",
    "regression_metrics",
    "profile_comparison"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "const": "ram-performance-result" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "source_commit": { "type": "string" },
    "preset": { "enum": ["full", "smoke"] },
    "runner_id": { "type": "string", "minLength": 1 },
    "environment": {
      "type": "object",
      "required": ["environment_fingerprint", "architecture", "cpu_model", "filesystem_type"],
      "properties": {
        "environment_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "architecture": { "type": "string" },
        "cpu_model": { "type": "string" },
        "filesystem_type": { "type": "string" }
      }
    },
    "configuration": {
      "type": "object",
      "required": ["strict_environment", "binary_contract"],
      "properties": {
        "strict_environment": { "type": "boolean" },
        "binary_contract": { "type": "string", "minLength": 1 }
      }
    },
    "profiles": { "type": "object", "minProperties": 1 },
    "regression_metrics": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "profile_comparison": { "type": "object" }
  }
}
