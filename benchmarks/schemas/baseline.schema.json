{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/isarmg/ram/benchmarks/schemas/baseline.schema.json",
  "title": "Ram reviewed performance baseline",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "baseline_id",
    "runner_id",
    "environment_fingerprint",
    "source_commit",
    "captured_at_utc",
    "preset",
    "threshold_policy_sha256",
    "metrics",
    "review"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "kind": { "const": "ram-performance-baseline" },
    "baseline_id": { "type": "string", "minLength": 1 },
    "runner_id": { "type": "string", "minLength": 1 },
    "environment_fingerprint": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "captured_at_utc": { "type": "string", "format": "date-time" },
    "preset": { "enum": ["full", "smoke"] },
    "threshold_policy_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "metrics": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "review": {
      "type": "object",
      "required": ["status", "approved_by", "approved_at_utc", "evidence_url", "notes"],
      "properties": {
        "status": { "enum": ["candidate", "smoke-candidate", "approved"] },
        "approved_by": { "type": "array", "items": { "type": "string" } },
        "approved_at_utc": { "type": ["string", "null"] },
        "evidence_url": { "type": ["string", "null"] },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "approved" } } },
          "then": {
            "properties": {
              "approved_by": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
              "approved_at_utc": { "type": "string", "format": "date-time" },
              "evidence_url": { "type": "string", "format": "uri", "pattern": "^https://" }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "review": { "properties": { "status": { "const": "approved" } } }
        }
      },
      "then": {
        "properties": {
          "preset": { "const": "full" },
          "runner_id": { "not": { "const": "local" } }
        }
      }
    }
  ]
}
